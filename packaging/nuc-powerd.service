[Unit]
Description=NUC Power Optimization Daemon
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/nuc-powerd
ExecStart=/usr/local/bin/nuc-powerd --config /etc/nuc-powerd.toml
Restart=always
RestartSec=2
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true

[Install]
WantedBy=multi-user.target
